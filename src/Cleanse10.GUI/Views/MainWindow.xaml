<Window x:Class="Cleanse10.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Cleanse10.ViewModels"
        xmlns:cv="clr-namespace:Cleanse10.Converters"
        Title="Cleanse10"
        Width="860" Height="680"
        MinWidth="720" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
    </Window.Resources>

    <Grid Margin="24,18,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- WIM / Mount row -->
            <RowDefinition Height="Auto"/>   <!-- Preset cards -->
            <RowDefinition Height="Auto"/>   <!-- Action buttons -->
            <RowDefinition Height="Auto"/>   <!-- Status / progress -->
            <RowDefinition Height="*"/>      <!-- Log -->
        </Grid.RowDefinitions>

        <!-- ══ Header ══════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Cleanse10" Style="{StaticResource H1}" FontSize="26"/>
            <TextBlock Text="Windows 10 image customization — pick a preset and run."
                       Style="{StaticResource Caption}" FontSize="12"/>
        </StackPanel>

        <!-- ══ WIM + Mount paths ══════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- WIM path -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="WIM / ESD file" Style="{StaticResource H2}" FontSize="12" Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding WimPath, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
                    <Button Grid.Column="1" Margin="6,0,0,0"
                            Content="Browse…"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding BrowseWimCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
                    <Button Grid.Column="2" Margin="6,0,0,0"
                            Content="Open ISO…"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding BrowseIsoCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                            ToolTip="Mount a local ISO and extract install.wim automatically"/>
                    <Button Grid.Column="3" Margin="6,0,0,0"
                            Content="Get ISO…"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding GetIsoCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                            ToolTip="Download Windows 10 22H2 Pro ISO directly from Microsoft"/>
                </Grid>
            </StackPanel>

            <!-- Mount path -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Mount folder (empty)" Style="{StaticResource H2}" FontSize="12" Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding MountPath, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
                    <Button Grid.Column="1" Margin="6,0,0,0"
                            Content="Browse…"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding BrowseMountCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- ══ Preset cards ══════════════════════════════════════════════════ -->
        <ItemsControl Grid.Row="2" Margin="0,0,0,16" ItemsSource="{Binding Presets}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:PresetCardViewModel}">
                    <Border Margin="0,0,10,0"
                            Padding="14,12"
                            CornerRadius="6"
                            Cursor="Hand">
                        <Border.ToolTip>
                            <ToolTip Style="{StaticResource PresetTooltip}">
                                <StackPanel Margin="14,12">
                                    <!-- Header -->
                                    <TextBlock Text="{Binding Definition.Name}"
                                               FontWeight="SemiBold" FontSize="13"
                                               Foreground="{StaticResource AccentBrush}"
                                               Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding Definition.Description}"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,10"/>

                                    <!-- Removes section -->
                                    <TextBlock Text="REMOVES"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,0,4"/>
                                    <ItemsControl ItemsSource="{Binding Definition.Removes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock FontSize="11" Margin="0,1"
                                                           Foreground="{StaticResource TextPrimaryBrush}">
                                                    <Run Text="&#x2212;&#x2002;" Foreground="#E05090"/>
                                                     <Run Text="{Binding Mode=OneWay}"/>
                                                 </TextBlock>
                                             </DataTemplate>
                                         </ItemsControl.ItemTemplate>
                                     </ItemsControl>

                                     <!-- Adds section (hidden when empty) -->
                                     <StackPanel Visibility="{Binding HasAdds,
                                                     Converter={StaticResource BoolVis}}"
                                                 Margin="0,10,0,0">
                                         <TextBlock Text="ADDS / ENABLES"
                                                    FontSize="10" FontWeight="SemiBold"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Margin="0,0,0,4"/>
                                         <ItemsControl ItemsSource="{Binding Definition.Adds}">
                                             <ItemsControl.ItemTemplate>
                                                 <DataTemplate>
                                                     <TextBlock FontSize="11" Margin="0,1"
                                                                Foreground="{StaticResource TextPrimaryBrush}">
                                                         <Run Text="&#x002B;&#x2002;" Foreground="#4CAF50"/>
                                                         <Run Text="{Binding Mode=OneWay}"/>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"      Value="{StaticResource SurfaceBrush}"/>
                                <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="Background"  Value="#FFE8F4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding DataContext.SelectPresetCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                          CommandParameter="{Binding}"/>
                        </Border.InputBindings>
                        <StackPanel>
                            <TextBlock Text="{Binding Definition.Icon}" FontSize="22" Margin="0,0,0,6"
                                       FontFamily="Segoe MDL2 Assets"/>
                            <TextBlock Text="{Binding Definition.Name}" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Text="{Binding Definition.Tagline}" Style="{StaticResource Caption}"
                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
            </ItemsControl>

        <!-- ══ Action buttons ════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Start Build"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding RunCommand}"
                    MinWidth="120" Margin="0,0,10,0"/>
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding CancelCommand}"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"
                    MinWidth="80"/>
        </StackPanel>

        <!-- ══ Status + progress ═════════════════════════════════════════════ -->
        <StackPanel Grid.Row="4" Margin="0,0,0,8">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,4"/>
            <ProgressBar Value="{Binding Progress, Mode=OneWay}"
                         Minimum="0" Maximum="100"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"/>
        </StackPanel>

        <!-- ══ Log output ════════════════════════════════════════════════════ -->
        <TextBox Grid.Row="5"
                 Style="{StaticResource LogBox}"
                 Text="{Binding Log, Mode=OneWay}"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"/>
    </Grid>
</Window>
