<Window x:Class="Cleanse10.Views.GetIsoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Get Windows 10 ISO"
        Width="520" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="Transparent">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Height="44">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Margin="16,0,0,0"
                               VerticalAlignment="Center"
                               Text="Get Windows 10 ISO"
                               Style="{StaticResource H2}"/>

                    <Button Grid.Column="1"
                            Width="44"
                            Height="44"
                            Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource TitleBarButton}"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="28,22,28,26">
                <TextBlock Text="Get Windows 10 ISO"
                           Style="{StaticResource H1}" FontSize="20" Margin="0,0,0,4"/>
                <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,22"
                           Text="Downloads an official Windows 10 22H2 Pro (English) ISO directly from Microsoft via Fido (github.com/pbatard/Fido). No license restriction - Home users can get Pro."/>

                <TextBlock Text="Save ISO to" Style="{StaticResource H2}" FontSize="12" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
                    <Button Grid.Column="1" Margin="6,0,0,0"
                            Content="Browse..." Style="{StaticResource SecondaryButton}"
                            Command="{Binding BrowseOutputCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
                </Grid>

                <StackPanel Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"
                            Margin="0,0,0,10">
                    <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                 Minimum="0" Maximum="100" Height="8" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding SpeedText}"
                               Style="{StaticResource Caption}" FontSize="11"/>
                </StackPanel>

                <TextBlock Text="{Binding StatusText}"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,18"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Download ISO"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding DownloadCommand}"
                            MinWidth="130" Margin="0,0,10,0"/>
                    <Button Content="Cancel"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding CancelCommand}"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"
                            MinWidth="80"/>
                </StackPanel>

                <StackPanel Visibility="{Binding IsDownloadComplete, Converter={StaticResource BoolVis}}"
                            Margin="0,22,0,0">
                    <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,18"/>

                    <TextBlock Text="Use with Cleanse10"
                               Style="{StaticResource H2}" FontSize="12" Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,14">
                        Mounts the ISO, copies <Run FontWeight="SemiBold">sources\install.wim</Run>
                        to the same folder, and loads it directly into the WIM path field.
                    </TextBlock>

                    <Button Content="Extract install.wim and load into Cleanse10"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding ExtractWimCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
